{
  "name": "agentifui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@agentifui/web",
    "dev:gateway": "turbo run dev --filter=@agentifui/gateway",
    "build": "turbo run build",
    "db:migrate": "npm run migrate --workspace @agentifui/db",
    "db:reset": "npm run reset --workspace @agentifui/db",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "smoke:browser": "node scripts/public-browser-smoke.mjs",
    "perf:seed": "node scripts/perf-seed.mjs",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "backup:export": "node scripts/backup-export.mjs",
    "backup:restore": "node scripts/backup-restore.mjs",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "test:unit": "vitest run --exclude apps/gateway/src/routes/auth-persistence.test.ts --exclude apps/gateway/src/routes/knowledge-persistence.test.ts --exclude apps/gateway/src/routes/tool-registry-persistence.test.ts",
    "test:persistence": "vitest run apps/gateway/src/routes/auth-persistence.test.ts && vitest run apps/gateway/src/routes/knowledge-persistence.test.ts && vitest run apps/gateway/src/routes/tool-registry-persistence.test.ts",
    "test": "npm run test:unit && npm run test:persistence",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.17.0",
    "drizzle-kit": "https://registry.npmjs.org/drizzle-kit/-/drizzle-kit-0.31.6.tgz",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
