{
  "name": "@agentifui/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/scripts/migrate.ts",
    "reset": "tsx src/scripts/reset.ts",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'db lint is not configured yet'"
  },
  "dependencies": {
    "drizzle-orm": "https://registry.npmjs.org/drizzle-orm/-/drizzle-orm-0.44.5.tgz",
    "postgres": "^3.4.7"
  }
}
