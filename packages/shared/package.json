{
  "name": "@agentifui/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "default": "./dist/auth/index.js"
    },
    "./apps": {
      "types": "./src/apps/index.ts",
      "default": "./dist/apps/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'shared lint is not configured yet'"
  }
}
