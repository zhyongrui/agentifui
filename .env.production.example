NODE_ENV=production
WEB_PORT=3112
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=4214
NEXT_PUBLIC_GATEWAY_URL=https://agentifui.example.com/api/gateway
GATEWAY_INTERNAL_URL=http://127.0.0.1:4214
GATEWAY_CORS_ORIGIN=https://agentifui.example.com
GATEWAY_DEFAULT_TENANT_ID=prod-tenant
GATEWAY_SSO_JIT_DEFAULT_STATUS=pending
GATEWAY_AUTH_LOCKOUT_THRESHOLD=5
GATEWAY_AUTH_LOCKOUT_DURATION_MS=1800000
GATEWAY_SSO_DOMAINS=iflabx.com=iflabx-sso
DATABASE_URL=postgresql://agentifui:replace-me@127.0.0.1:5432/agentifui
REDIS_URL=redis://127.0.0.1:6379
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://agentifui.example.com/api/gateway
GATEWAY_UPLOADS_DIR=/var/lib/agentifui/uploads
